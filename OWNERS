# See the OWNERS docs at https://go.k8s.io/owners
#
# Path-specific QE ownership uses the qe-team alias in OWNERS_ALIASES (GitHub
# usernames from org team https://github.com/orgs/medik8s/teams/qe — Prow does
# not resolve @org/team handles).

filters:
  ".*":
    reviewers:
      - code-reviewers
    approvers:
      - approvers
  "^\\.prow/":
    approvers:
      - qe-team
    reviewers:
      - qe-team
  "^test/":
    approvers:
      - qe-team
    reviewers:
      - qe-team
  "^\\.github/workflows/test\\.yml$":
    approvers:
      - qe-team
    reviewers:
      - qe-team
  "^bundle/tests/":
    approvers:
      - qe-team
    reviewers:
      - qe-team
